# Optional: WalletConnect Cloud project id (enables the WalletConnect QR connector).
# Get one free at https://cloud.walletconnect.com. Without it, the app still works
# with browser-injected wallets (MetaMask, Rabby, etc.) and Coinbase Wallet.
VITE_WALLETCONNECT_PROJECT_ID=

# Optional: imgbb API key. Enables token logo uploads from the Create page.
# Get one free at https://api.imgbb.com.
VITE_IMGBB_API_KEY=

# Which network the UI targets first: "base" (mainnet) or "baseSepolia" (testnet).
VITE_DEFAULT_CHAIN=base
